# Production environment variables
# Copy this file, fill in real values, and set them as ECS task environment variables
# DO NOT commit real values to git

# PostgreSQL connection string (Neon or RDS)
# Neon format:    postgresql+asyncpg://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# RDS format:     postgresql+asyncpg://user:password@your-rds-host.rds.amazonaws.com:5432/expense_db
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/expense_db

# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your-secure-random-api-key-here

ENVIRONMENT=production
LOG_LEVEL=INFO

# Must be "sse" for ECS/hosted deployment
MCP_TRANSPORT=sse
PORT=8000
HOST=0.0.0.0
