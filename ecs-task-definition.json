{
  "family": "expense-mcp",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::031788956343:role/ecsTaskExecutionRole-expense-mcp",
  "containerDefinitions": [
    {
      "name": "expense-mcp",
      "image": "031788956343.dkr.ecr.ap-southeast-1.amazonaws.com/expense-mcp:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "MCP_TRANSPORT", "value": "sse" },
        { "name": "PORT",          "value": "8000" },
        { "name": "ENVIRONMENT",   "value": "production" },
        { "name": "LOG_LEVEL",     "value": "INFO" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:031788956343:secret:expense-mcp/DATABASE_URL-SqcAx4"
        },
        {
          "name": "API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:031788956343:secret:expense-mcp/API_KEY-HhlVfk"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "ecs-expense-mcp",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:8000/health || exit 1"
        ],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 15
      }
    }
  ]
}
